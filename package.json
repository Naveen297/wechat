    "clsx": "^2.0.0",
    "framer-motion": "^10.16.5",
    "html5-qrcode": "^2.3.8",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.1",
    "recharts": "^3.3.0",
    "simple-peer": "^9.11.1",
